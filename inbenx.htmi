<style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Rajdhani:wght@600;700&family=Share+Tech+Mono&display=swap');
        
        /* 🌌 NEON TOXIC PURPLE & BLOOD RED V44 SYSTEM THEME */
        :root { 
            --cyber-neon: #ff0055;
            --cyber-glow: #00ffcc;
            --toxic-purple: #9d00ff;
            --panel-bg: rgba(6, 4, 12, 0.85);
            --dark-core: #030206;
            --gold-glow: #ffd700;
            --glass-bg: rgba(6, 2, 15, 0.45);
            --glass-border: rgba(255, 255, 255, 0.12);
        }
        
        body, html { margin:0; padding:0; height:100%; background: #010103; overflow: hidden; font-family: 'Rajdhani', sans-serif; user-select: none; }
        #gameFrame { width: 100%; height: 100vh; border: none; z-index: 1; display: block; }
        
        /* ⚡ ULTRA-DANGEROUS HACKER LOADING SCREEN */
        #loadingScreen { 
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
            background: radial-gradient(circle at center, #120124 0%, #000000 100%); 
            z-index: 999999; display: flex; flex-direction: column; align-items: center; justify-content: center; 
            border: 3px solid var(--cyber-neon); box-sizing: border-box;
            box-shadow: inset 0 0 120px rgba(255, 0, 85, 0.3);
            opacity: 1; transition: opacity 0.5s ease-out;
        }
        .cyber-hacker-icon { font-size: 60px; color: var(--cyber-glow); text-shadow: 0 0 30px var(--cyber-glow); animation: glitchPulse 0.5s infinite alternate; margin-bottom: 25px; }
        .ramu-brand-title { font-size: 26px; font-weight: 900; color: #fff; text-align: center; letter-spacing: 2px; font-family: 'Orbitron', sans-serif; text-shadow: 0 0 20px var(--cyber-neon); margin-bottom: 10px; }
        .system-status-log { font-size: 12px; font-weight: 700; color: var(--cyber-glow); text-align: center; letter-spacing: 3px; font-family: 'Share Tech Mono', monospace; margin-bottom: 35px; text-transform: uppercase; }
        .matrix-progress-bar { width: 260px; height: 6px; background: rgba(0, 255, 204, 0.05); border-radius: 4px; border: 1px solid var(--cyber-glow); overflow: hidden; box-shadow: 0 0 20px rgba(0, 255, 204, 0.3); }
        .matrix-fill { width: 0%; height: 100%; background: linear-gradient(90deg, var(--toxic-purple), var(--cyber-neon), var(--cyber-glow)); }
        .realtime-text-counter { font-family: 'Share Tech Mono'; font-size: 12px; color: #fff; margin-top: 15px; letter-spacing: 2px; }

        /* 🛑 REGISTRATION NOTICE POPUP */
        #registrationWarningModal {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(2, 1, 4, 0.96); backdrop-filter: blur(25px);
            z-index: 999998; display: none; align-items: center; justify-content: center; padding: 20px; box-sizing: border-box;
        }
        .warning-card {
            width: 340px; background: #0b0714; border: 2px solid var(--cyber-neon); border-radius: 20px;
            padding: 30px 20px; text-align: center; box-shadow: 0 0 45px rgba(255, 0, 85, 0.4);
            animation: cyberPop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .warning-card h2 { font-family: 'Orbitron'; color: var(--cyber-glow); font-size: 20px; margin: 0 0 18px 0; text-shadow: 0 0 12px var(--cyber-glow); }
        .warning-text-content { color: #e2def2; font-size: 14px; font-weight: 600; line-height: 1.6; text-align: left; background: rgba(157, 0, 255, 0.06); padding: 18px; border-radius: 12px; border: 1px solid rgba(0, 255, 204, 0.2); margin-bottom: 25px; }
        .warning-ok-btn {
            width: 100%; background: linear-gradient(90deg, var(--cyber-neon), var(--toxic-purple)); border: none; border-radius: 10px;
            padding: 14px; color: #fff; font-size: 13px; font-weight: 900; font-family: 'Orbitron'; cursor: pointer;
            box-shadow: 0 5px 20px rgba(255, 0, 85, 0.4); text-transform: uppercase; letter-spacing: 2px;
        }

        /* 🎛️ HUD NAVBAR TRIGGER SYSTEM */
        .top-btn-navbar { position: fixed; top: 12px; right: 12px; display: flex; gap: 10px; z-index: 10000; background: rgba(11, 7, 20, 0.8); backdrop-filter: blur(15px); padding: 6px 12px; border-radius: 20px; border: 1px solid rgba(0, 255, 204, 0.3); }
        .action-btn { width: 38px; height: 38px; background: rgba(0, 0, 0, 0.7); border: 2px solid var(--cyber-neon); border-radius: 12px; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 15px; cursor: pointer; box-shadow: 0 0 10px rgba(255, 0, 85, 0.3); transition: all 0.3s; }
        .action-btn:hover { transform: scale(1.05); border-color: var(--cyber-glow); color: var(--cyber-glow); }
        .tg-top-btn { border-color: #00ffcc !important; color: #00ffcc; box-shadow: 0 0 10px rgba(0, 255, 204, 0.3); }
        .mines-top-btn { border-color: var(--gold-glow) !important; color: var(--gold-glow) !important; box-shadow: 0 0 10px rgba(255, 215, 0, 0.3); }
        
        /* 🔐 VERIFICATION INTERFACE MODAL */
        #cryptoAuthModal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(3, 2, 6, 0.98); backdrop-filter: blur(25px); z-index: 99999; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: all 0.4s ease; padding: 15px; }
        #cryptoAuthModal.visible { opacity: 1; pointer-events: auto; }
        .crypto-card { width: 330px; background: #07050d; border: 2px solid var(--cyber-glow); border-radius: 22px; padding: 25px; text-align: center; box-shadow: 0 15px 50px rgba(0, 255, 204, 0.3); }
        .warning-notice-box { background: rgba(0, 255, 204, 0.04); border: 1px dashed var(--cyber-glow); border-radius: 12px; padding: 14px; text-align: center; margin-bottom: 20px; }
        .warning-notice-box i { font-size: 20px; color: var(--cyber-neon); animation: glitchPulse 0.6s infinite alternate; }
        .warning-notice-box p { color: #e2def2; font-size: 13px; font-weight: 700; line-height: 1.5; margin-top: 6px; }
        .crypto-input { width: 100%; background: rgba(0,0,0,0.8); border: 1px solid var(--cyber-neon); border-radius: 10px; padding: 12px; text-align: center; font-size: 16px; color: #fff; margin-bottom: 15px; font-family: 'Share Tech Mono'; outline: none; letter-spacing: 4px; box-sizing: border-box; box-shadow: inset 0 0 10px rgba(255, 0, 85, 0.2); }
        .crypto-btn { width: 100%; background: linear-gradient(90deg, var(--cyber-glow), var(--toxic-purple)); border: none; border-radius: 10px; padding: 13px; color: #000; font-size: 13px; font-weight: 900; font-family: 'Orbitron'; cursor: pointer; text-transform: uppercase; margin-bottom: 12px; box-shadow: 0 4px 20px rgba(0, 255, 204, 0.4); letter-spacing: 1px; }
        .tg-link-btn { display: inline-flex; align-items: center; justify-content: center; background: #00ffcc; color: #000; text-decoration: none; padding: 12px; border-radius: 10px; font-size: 13px; font-weight: 900; font-family: 'Orbitron'; width: 100%; box-sizing: border-box; letter-spacing: 0.5px; box-shadow: 0 4px 15px rgba(0,255,204,0.2); }
        #coreVerifyScreen { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: #040207; display: none; flex-direction: column; align-items: center; justify-content: center; z-index: 2; border-radius: 20px; }
        .verify-spinner { width: 44px; height: 44px; border: 3px solid rgba(0,255,204,0.1); border-top-color: var(--cyber-glow); border-radius: 50%; animation: spin 0.8s linear infinite; margin-bottom: 15px; }
        
        /* 🛸 NEON CYBERPUNK DRAGGABLE PREMIUM PANEL */
        #choudharyPredPanel { 
            position: fixed; top: 40%; left: 50%; transform: translate(-50%, -50%); width: 345px; max-height: 94vh; 
            background: var(--panel-bg) !important; backdrop-filter: blur(22px) saturate(160%); -webkit-backdrop-filter: blur(22px) saturate(160%); 
            border-radius: 24px; z-index: 9998; display: none; flex-direction: column; align-items: center; justify-content: flex-start; 
            padding: 14px; box-sizing: border-box; border: 2px solid var(--cyber-neon); 
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.95), inset 0 0 25px rgba(255, 0, 85, 0.15); touch-action: none; gap: 8px; 
        }
        .brand-header { width: 100%; text-align: center; font-size: 14px; font-weight: 900; color: #fff; background: linear-gradient(90deg, transparent, rgba(255, 0, 85, 0.25), transparent); padding: 8px 0; border-bottom: 1px solid rgba(255, 0, 85, 0.4); letter-spacing: 1px; font-family: 'Orbitron', serif; text-shadow: 0 0 12px var(--cyber-neon); }
        .mines-brand-header { text-shadow: 0 0 12px var(--gold-glow); border-bottom: 1px solid rgba(255, 215, 0, 0.4); background: linear-gradient(90deg, transparent, rgba(255, 215, 0, 0.15), transparent); }

        .live-score-counter { width: 100%; display: grid; grid-template-columns: repeat(4, 1fr); gap: 5px; text-align: center; }
        .score-box { background: rgba(0, 0, 0, 0.8); padding: 7px 2px; border-radius: 10px; border: 1px solid rgba(255, 0, 85, 0.2); font-size: 10px; font-weight: 700; color: #b5b0cc; }
        .score-box span { display: block; font-size: 13px; font-weight: 900; margin-top: 2px; font-family: 'Share Tech Mono'; color: #fff; text-shadow: 0 0 5px #fff; }
        
        .mode-selector { display: flex; gap: 6px; width: 100%; background: rgba(0,0,0,0.6); padding: 4px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); }
        .mode-btn { flex: 1; text-align: center; font-size: 10px; font-weight: 800; padding: 8px 0; color: #8e88a5; cursor: pointer; border-radius: 8px; background: transparent; border: none; font-family: 'Orbitron'; }
        .mode-btn.active { background: rgba(255, 0, 85, 0.15); color: #fff; border: 1px solid var(--cyber-neon); text-shadow: 0 0 8px var(--cyber-neon); }
        
        /* RESULTS INTERFACE ENGINE */
        .result-display-box { position: relative; width: 100%; display: flex; align-items: center; justify-content: center; height: 62px; overflow: hidden; border-radius: 12px; background: #030106; border: 1.5px solid rgba(0, 255, 204, 0.3); }
        .mines-display-box { border-color: var(--gold-glow); box-shadow: 0 0 15px rgba(255, 215, 0, 0.2); }
        #mainSizeText, #minesStatusText { font-size: 18px; font-weight: 900; color: #fff; text-transform: uppercase; z-index: 6; letter-spacing: 1px; font-family: 'Orbitron'; }
        .laser-line { position: absolute; top: 0; left: 0; width: 100%; height: 3px; background: linear-gradient(90deg, transparent, var(--cyber-glow), #fff, transparent); box-shadow: 0 0 15px var(--cyber-glow); display: none; z-index: 10; animation: scanVertical 1.2s linear infinite; }
        
        @keyframes scanVertical { 0% { top: 0%; } 50% { top: 94%; } 100% { top: 0%; } }
        .panel-footer-info { display: flex; width: 100%; gap: 6px; }
        .period-info, .timer-info { flex: 1; text-align: center; color: #fff; background: rgba(0, 0, 0, 0.7); padding: 8px 0; border-radius: 10px; font-size: 12px; font-weight: 700; border: 1px solid rgba(255, 0, 85, 0.15); }
        .period-info span { color: var(--cyber-glow); font-weight: 900; font-family: 'Share Tech Mono'; text-shadow: 0 0 5px var(--cyber-glow); }
        .timer-info span { color: #fff; font-weight: 900; font-family: 'Share Tech Mono'; }
        
        /* DATA SYSTEM LIST */
        .history-section { width: 100%; background: rgba(0, 0, 0, 0.7); border-radius: 12px; padding: 6px; border: 1px solid rgba(0, 255, 204, 0.15); overflow-y: auto; max-height: 140px; box-sizing: border-box; }
        table { width: 100%; border-collapse: collapse; font-size: 11px; }
        th, td { padding: 6px 4px; text-align: center; font-weight: 700; border-bottom: 1px solid rgba(255,255,255,0.03); }
        th { color: var(--cyber-glow); border-bottom: 1px solid var(--cyber-glow); position: sticky; top: 0; background: #07040d; z-index: 1; font-size: 10px; font-family: 'Orbitron'; }
        .win { color: var(--cyber-glow) !important; font-weight: 900; text-shadow: 0 0 5px var(--cyber-glow); }
        .loss { color: var(--cyber-neon) !important; font-weight: 900; text-shadow: 0 0 5px var(--cyber-neon); }
        .jackpot-glow { color: #ffff00 !important; font-weight: 900; text-shadow: 0 0 10px #ffff00; }

        /* 💎 TRANSPARENT MINES DRAGGABLE COMPACT PANEL */
        #minesPredPanel { 
            position: fixed; top: 62%; left: 50%; transform: translate(-50%, -50%); width: 345px; 
            background: var(--panel-bg) !important; backdrop-filter: blur(22px) saturate(160%); -webkit-backdrop-filter: blur(22px) saturate(160%);
            border-radius: 24px; z-index: 9997; display: none; flex-direction: column; padding: 14px; box-sizing: border-box; 
            border: 2px solid var(--gold-glow); box-shadow: 0 30px 60px rgba(0, 0, 0, 0.95), inset 0 0 25px rgba(255, 215, 0, 0.1); touch-action: none; gap: 8px; 
        }

        /* 💎 MINES GRID SYSTEM */
        .mines-grid-5x5 {
            display: grid; grid-template-columns: repeat(5, 1fr); gap: 5px; width: 100%; justify-content: center;
            background: rgba(0, 0, 0, 0.7); padding: 8px; border-radius: 14px; border: 1px solid rgba(255, 215, 0, 0.15); box-sizing: border-box;
            position: relative;
        }
        .mine-cell {
            aspect-ratio: 1; background: rgba(5, 2, 12, 0.8); border: 1px solid rgba(255, 215, 0, 0.15);
            border-radius: 8px; display: flex; align-items: center; justify-content: center;
            font-size: 16px; position: relative; transition: all 0.3s;
        }
        .mine-cell.has-star {
            background: radial-gradient(circle, #4a3302 0%, rgba(17, 8, 1, 0.8) 100%); border-color: var(--gold-glow);
            box-shadow: 0 0 12px rgba(255, 215, 0, 0.5);
        }
        .mine-cell.is-safe { background: rgba(0, 255, 204, 0.01); border-color: rgba(0, 255, 204, 0.05); }
        .mine-cell span { opacity: 0; transform: scale(0.3); transition: all 0.4s ease; }
        .mine-cell.revealed span { opacity: 1; transform: scale(1); }
        
        .grid-loading-overlay {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(4, 1, 10, 0.96);
            border-radius: 14px; z-index: 10; display: none; flex-direction: column; align-items: center; justify-content: center;
            color: var(--gold-glow); font-family: 'Share Tech Mono'; font-size: 13px; letter-spacing: 1px;
        }
        .grid-loading-overlay i { font-size: 24px; animation: spin 0.8s linear infinite; margin-bottom: 8px; color: var(--cyber-glow); }

        .extract-btn {
            width: 100%; background: linear-gradient(90deg, #ff9900, var(--gold-glow)); border: none; border-radius: 10px;
            padding: 11px; color: #000; font-size: 13px; font-weight: 900; font-family: 'Orbitron'; cursor: pointer;
            text-transform: uppercase; letter-spacing: 1px; box-shadow: 0 5px 20px rgba(255, 215, 0, 0.3); transition: all 0.3s;
        }
        .extract-btn:disabled { background: #221a0e; color: #555; border: 1px solid #33220a; box-shadow: none; cursor: not-allowed; }
        
        /* BROADCAST FEED MODAL */
        #fullscreenAlert { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 100000; display: none; flex-direction: column; align-items: center; justify-content: center; backdrop-filter: blur(12px); }
        .alert-content { padding: 35px 50px; border-radius: 20px; text-align: center; font-size: 40px; font-weight: 900; letter-spacing: 2px; box-shadow: 0 0 60px rgba(0,0,0,0.9); font-family: 'Orbitron'; }
        .alert-sub { font-size: 15px; letter-spacing: 1px; color: #fff; margin-top: 10px; font-weight: bold; font-family: 'Rajdhani'; }
        .alert-win { background: rgba(2, 22, 18, 0.96); border: 2.5px solid var(--cyber-glow); color: var(--cyber-glow); text-shadow: 0 0 25px var(--cyber-glow); }
        .alert-loss { background: rgba(26, 2, 12, 0.96); border: 2.5px solid var(--cyber-neon); color: var(--cyber-neon); text-shadow: 0 0 25px var(--cyber-neon); }
        
        @keyframes cyberPop { from { transform: scale(0.7); opacity: 0; } to { transform: scale(1); opacity: 1; } }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        @keyframes glitchPulse { 0% { opacity: 0.7; transform: scale(0.97); filter: hue-rotate(0deg); } 100% { opacity: 1; transform: scale(1.03); filter: hue-rotate(20deg); } }
